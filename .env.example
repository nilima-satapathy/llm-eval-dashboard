# Copy to .env and fill in (never commit .env)

# mock = offline placeholder | golden = reference answers (offline eval) | openai = live LLM
# For M3 pytest offline: use golden
TARGET_BACKEND=golden

# Required when TARGET_BACKEND=openai (OpenAI, or xAI via base URL)
OPENAI_API_KEY=
# Optional: use XAI_API_KEY instead if talking to xAI only
# XAI_API_KEY=

# OpenAI default: https://api.openai.com/v1
# xAI Grok example: https://api.x.ai/v1
OPENAI_BASE_URL=https://api.openai.com/v1

# Examples: gpt-4o-mini | gpt-4o | grok-2-latest
OPENAI_MODEL=gpt-4o-mini

# M5 — rough cost estimate when token counts are present ($ per 1M tokens)
ESTIMATED_USD_PER_1M_TOKENS=0.15

# Metric pass thresholds used by runners.py
MUST_INCLUDE_THRESHOLD=0.7
OVERLAP_THRESHOLD=0.85
