# Copy to .env and fill in (never commit .env)
# Free AI guide: docs/FREE_AI.md

# mock | golden (free offline) | openai (OpenAI-compatible: Ollama / Groq / OpenAI / xAI)
TARGET_BACKEND=golden

# --- Free local AI (Ollama) ---
# TARGET_BACKEND=openai
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_API_KEY=ollama
# OPENAI_MODEL=llama3.2

# --- Free cloud example (Groq free tier) ---
# TARGET_BACKEND=openai
# OPENAI_BASE_URL=https://api.groq.com/openai/v1
# OPENAI_API_KEY=gsk_...
# OPENAI_MODEL=llama-3.1-8b-instant

# --- Paid OpenAI ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=sk-...
# OPENAI_MODEL=gpt-4o-mini

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_MODEL=gpt-4o-mini
# XAI_API_KEY=
# GROQ_API_KEY=


# M5 — rough cost estimate when token counts are present ($ per 1M tokens)
ESTIMATED_USD_PER_1M_TOKENS=0.15

# Free-tier budget shown on the dashboard (defaults = Groq llama-3.1-8b-instant free tier)
# Usage is counted from this app's stored openai runs only — not your full cloud account.
FREE_TIER_PROVIDER=groq
FREE_TIER_DAILY_REQUESTS=14400
FREE_TIER_DAILY_TOKENS=500000
FREE_TIER_RPM=30
FREE_TIER_TPM=6000
# Optional soft monthly $ budget (leave empty if free tier has no $ credits)
# FREE_TIER_MONTHLY_USD=0

# Metric pass thresholds — golden/mock (strict harness)
MUST_INCLUDE_THRESHOLD=0.7
OVERLAP_THRESHOLD=0.85

# Live LLM (openai / Groq) — looser so paraphrases can pass
LIVE_MUST_INCLUDE_THRESHOLD=0.5
LIVE_OVERLAP_THRESHOLD=0.12
# Seconds between cloud API calls (reduces free-tier 429 rate limits)
LIVE_REQUEST_DELAY_S=2.0
